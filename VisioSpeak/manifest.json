{
  "manifest_version": 3,
  "name": "VisioSpeak",
  "version": "1.0.0",
  "description": "Real-time speech-to-text captions.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "VisioSpeak"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"]
}
